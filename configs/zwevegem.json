{
  "$schema": "Data Companion Dashboard Config v0.1",
  "_comment": "Dit bestand definieert het volledige dashboard voor Zwevegem. Pas aan om indicatoren, lagen en stijl te wijzigen.",

  "gemeente": {
    "naam": "Zwevegem",
    "niscode": "34042",
    "fallback_centrum": [50.81, 3.34]
  },

  "dashboard": {
    "titel": "Zwevegem in cijfers",
    "subtitel": "Beleidsdashboard · SDG-monitoring",
    "kleuren": {
      "primair": "#1a5c3a",
      "accent": "#e67e22"
    }
  },

  "bronvermelding": [
    { "naam": "Geopunt / Digitaal Vlaanderen", "url": "https://www.geopunt.be" },
    { "naam": "Basisregisters Vlaanderen", "url": "https://basisregisters.vlaanderen.be" }
  ],

  "panelen": [
    {
      "titel": "Kerncijfers",
      "items": [
        {
          "type": "indicator",
          "bron": "static",
          "titel": "Inwoners",
          "waarde": "26.040",
          "eenheid": "",
          "bronlabel": "Statbel 2024",
          "actie": "zoom_naar_gemeente"
        },
        {
          "type": "indicator",
          "bron": "static",
          "titel": "Oppervlakte",
          "waarde": "55,4",
          "eenheid": "km²",
          "bronlabel": "GRB"
        },
        {
          "type": "indicator",
          "bron": "static",
          "titel": "Deelgemeenten",
          "waarde": "5",
          "eenheid": "",
          "bronlabel": "Sint-Denijs · Heestert · Otegem · Moen · Zwevegem"
        }
      ]
    },

    {
      "titel": "Kaartlagen",
      "beschrijving": "Achtergronddata van Vlaamse open bronnen",
      "items": [
        {
          "type": "toggle",
          "bron": "wms",
          "label": "GRB basiskaart",
          "kleur": "#1a5c3a",
          "url": "https://geo.api.vlaanderen.be/GRB/wms",
          "layer": "GRB_BSK",
          "attribution": "GRB / Digitaal Vlaanderen",
          "standaard_aan": true
        },
        {
          "type": "toggle",
          "bron": "wfs",
          "label": "Gemeentegrenzen Vlaanderen",
          "kleur": "#2980b9",
          "url": "https://geo.api.vlaanderen.be/VRBG/wfs",
          "typename": "VRBG:Refgem",
          "count": 350,
          "stijl": {
            "color": "#2980b9",
            "weight": 1.5,
            "fillColor": "#2980b9",
            "fillOpacity": 0.04,
            "dashArray": "5 4"
          },
          "popup_label": "Gemeente",
          "popup_titel": "{NAAM}",
          "popup_body": "NIS-code: {NISCODE}",
          "standaard_aan": false
        }
      ]
    },

    {
      "titel": "Geplande uitbreidingen",
      "beschrijving": "In een productie-dashboard zou hier komen:",
      "items": [
        {
          "type": "indicator",
          "bron": "static",
          "titel": "Kansarmoede-indicator",
          "waarde": "TBD",
          "eenheid": "",
          "bronlabel": "Kind & Gezin"
        },
        {
          "type": "indicator",
          "bron": "static",
          "titel": "Verharding 2024",
          "waarde": "TBD",
          "eenheid": "%",
          "bronlabel": "Geopunt onthardingsscanner"
        }
      ]
    }
  ]
}
