            }
          ]
        },
        {
          "label": "Zorgvoorzieningen",
          "lagen": [
            {
              "id": "zorg_poi",
              "label": "Zorgvoorzieningen (Dept. Zorg)",
              "bron": "poi",
              "url": "https://geo.api.vlaanderen.be/POI/ogc/features/v1/collections/POI/items",
              "categorie": "Welzijn, gezondheid en gezin",
              "badge_grootte": 500,
              "max_items": 5000,
              "default_aan": false,
              "kleur_marker": "#e74c3c",
