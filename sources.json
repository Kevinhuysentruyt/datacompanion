    "attribution": "Voorlopig Referentiebestand Gemeentegrenzen © Digitaal Vlaanderen",
    "attribution_url": "https://www.geopunt.be",
    "update_frequentie": "jaarlijks"
  },

  "geopunt:zorgvoorzieningen": {
    "type": "geojson_url",
    "label": "Zorgvoorzieningen (Departement Zorg)",
    "url": "data/zorgvoorzieningen.geojson",
    "kleur_marker": "#e74c3c",
    "popup_label": "Zorgvoorziening",
    "popup_velden": ["name", "type", "address", "municipality"],
    "attribution": "Zorgvoorzieningen © Departement Zorg · Digitaal Vlaanderen",
    "attribution_url": "https://www.vlaanderen.be/datavindplaats/catalogus/zorgvoorzieningen-erkend-door-het-departement-zorg-gezondheidszorg-en-woonzorg-via-poi-service",
    "update_frequentie": "maandelijks via pipeline",
    "pipeline": "pipelines/zorg_pipeline.py",
    "_comment": "Data wordt lokaal gegenereerd via pipeline en als GeoJSON in data/ opgeslagen"
  },

  "stadsmonitor:kerncijfers": {
