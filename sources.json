{
  "$schema": "Data Companion — Broncatalogus v1.0",
  "_comment": "Centrale catalogus van alle beschikbare Vlaamse databronnen. Gemeente-configs verwijzen naar bronnen bij naam (bv. 'geopunt:grb'). Technische details staan enkel hier — nooit in gemeente-configs.",

  "geopunt:grb": {
    "type": "wms",
    "label": "GRB basiskaart",
    "url": "https://geo.api.vlaanderen.be/GRB/wms",
    "layer": "GRB_BSK",
    "transparantie": 0.9,
    "attribution": "Grootschalig Referentiebestand © Digitaal Vlaanderen",
    "attribution_url": "https://www.geopunt.be",
    "update_frequentie": "continu"
  },

  "geopunt:orthofoto_2021": {
    "type": "wms",
    "label": "Orthofoto zomer 2021 (kleur, 40cm)",
    "url": "https://geo.api.vlaanderen.be/OMZ/wms",
    "layer": "OI.OrthoimageCoverage.OMZ.RGB",
    "transparantie": 1.0,
    "attribution": "Orthofotomozaïek 2021 © Digitaal Vlaanderen",
    "attribution_url": "https://www.vlaanderen.be/datavindplaats/catalogus/orthofotomozaiek-middenschalig-zomeropnamen-2021-vlaanderen",
    "update_frequentie": "eenmalig (jaargang 2021)"
  },

  "geopunt:gemeentegrenzen": {
    "type": "wfs",
    "label": "Gemeentegrenzen Vlaanderen",
    "url": "https://geo.api.vlaanderen.be/VRBG/wfs",
    "typename": "VRBG:Refgem",
    "count": 400,
    "stijl": {
      "color": "#2980b9",
      "weight": 1.5,
      "fillColor": "#2980b9",
      "fillOpacity": 0.04,
      "dashArray": "5 4"
